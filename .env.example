# ── Backend ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_SECRET=change-me-random-secret        # required in production (NODE_ENV=production)
PORT=3001
DB_PATH=/app/data/db.sqlite
CRON_SCHEDULE=0 3 * * *
GITHUB_TOKEN=                               # optional - raises GitHub rate limit to 5000/hr
ANTHROPIC_MODEL=claude-sonnet-4-6
PROMPT_VERSION=1.0.0
CORS_ORIGIN=https://your-app.vercel.app     # set to your Vercel URL in production

# ── Rate Limits (requests per minute per IP) ─────────────────
# RATE_LIMIT_GENERAL=120
# RATE_LIMIT_ADMIN=10
# RATE_LIMIT_QA=5

# ── QA ───────────────────────────────────────────────────────
# QA_MAX_LENGTH=1000

# ── Changelog Cache ──────────────────────────────────────────
# CHANGELOG_CACHE_TTL_MS=3600000              # default 1 hour

# ── SimulationCraft Source ───────────────────────────────────
# SIMC_REPO=simulationcraft/simc
# SIMC_BRANCH=midnight
# SIMC_APL_PATH=ActionPriorityLists/default

# ── Project GitHub Repo ──────────────────────────────────────
# PROJECT_REPO=Brandon82/SimCRotationGuides

# ── Frontend (Vercel only) ────────────────────────────────────
VITE_API_BASE_URL=https://your-app.up.railway.app  # set to your Railway URL in production
